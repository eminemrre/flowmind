# Environment Variables Template
# Bu dosyayı .env olarak kopyala ve kendi API key'lerini ekle

# OpenRouter AI API
EXPO_PUBLIC_OPENROUTER_API_KEY=your_openrouter_api_key_here

# VDS Backend API
EXPO_PUBLIC_API_BASE_URL=https://your-vds-server.com/api

# App Settings
EXPO_PUBLIC_APP_ENV=development
